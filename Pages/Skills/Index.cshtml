@page
@model MyWebApp.Pages.Skills.IndexModel
@{
    ViewData["Title"] = "Skills";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Skill Categories</h1>
        <p class="text-muted mb-0">Choose a skill area and explore related learning materials.</p>
    </div>
</div>

<div class="row g-3">
    @foreach (var skill in Model.Skills)
    {
        <div class="col-md-6">
            <div class="section-card h-100 p-4">
                <h2 class="h4">@skill.SkillName</h2>
                <p class="text-muted">@skill.Description</p>
                <a class="btn btn-outline-primary" asp-page="/Resources/Index" asp-route-skillId="@skill.SkillID">View Resources</a>
            </div>
        </div>
    }
</div>
