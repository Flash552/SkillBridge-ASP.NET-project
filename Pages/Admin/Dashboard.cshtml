@page
@model MyWebApp.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-heading">
    <span class="eyebrow">Admin Area</span>
    <h1 class="mb-2">Admin Dashboard</h1>
    <p class="text-muted mb-0">Manage SkillBridge users, resources, quizzes, and database records.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="dashboard-card p-4"><span class="eyebrow">Accounts</span><h2 class="h6 mt-2">Users</h2><p class="display-6 mb-0">@Model.UserCount</p></div></div>
    <div class="col-md-3"><div class="dashboard-card p-4"><span class="eyebrow">Categories</span><h2 class="h6 mt-2">Skills</h2><p class="display-6 mb-0">@Model.SkillCount</p></div></div>
    <div class="col-md-3"><div class="dashboard-card p-4"><span class="eyebrow">Library</span><h2 class="h6 mt-2">Resources</h2><p class="display-6 mb-0">@Model.ResourceCount</p></div></div>
    <div class="col-md-3"><div class="dashboard-card p-4"><span class="eyebrow">Assessment</span><h2 class="h6 mt-2">Quizzes</h2><p class="display-6 mb-0">@Model.QuizCount</p></div></div>
</div>

<div class="section-card p-4">
    <span class="eyebrow">Database control</span>
    <h2 class="h4">Management Links</h2>
    <p class="text-muted">Use these pages to demonstrate insert, display, update, and delete operations.</p>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary" asp-page="/Admin/Users">Manage Users</a>
        <a class="btn btn-primary" asp-page="/Admin/Skills">Manage Skills</a>
        <a class="btn btn-primary" asp-page="/Admin/Resources">Manage Resources</a>
        <a class="btn btn-primary" asp-page="/Admin/Quizzes">Manage Quizzes</a>
        <a class="btn btn-primary" asp-page="/Admin/Questions">Manage Questions</a>
        <a class="btn btn-outline-primary" asp-page="/Admin/Results">View Results</a>
    </div>
</div>
