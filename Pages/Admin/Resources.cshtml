@page
@model MyWebApp.Pages.Admin.ResourcesModel
@{
    ViewData["Title"] = "Manage Resources";
}

<h1>Manage Resources</h1>

<div class="form-panel mb-4">
    <h2 class="h4">Add Resource</h2>
    <form method="post" asp-page-handler="Save">
        <input type="hidden" name="ResourceID" value="0" />
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Skill</label>
                <select class="form-select" name="SkillID" required>
                    @foreach (var skill in Model.Skills)
                    {
                        <option value="@skill.SkillID">@skill.SkillName</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Type</label>
                <select class="form-select" name="Type" required>
                    <option>Video</option>
                    <option>PDF</option>
                    <option>Link</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Title</label>
                <input class="form-control" name="Title" required />
            </div>
            <div class="col-md-6">
                <label class="form-label">URL</label>
                <input class="form-control" name="URL" type="url" required />
            </div>
            <div class="col-12">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="Description" required></textarea>
            </div>
        </div>
        <button class="btn btn-primary mt-3" type="submit">Add Resource</button>
    </form>
</div>

<div class="table-panel">
    <table class="table align-middle mb-0">
        <thead><tr><th>Resource</th><th>Skill</th><th>Type</th><th>URL</th><th>Actions</th></tr></thead>
        <tbody>
            @foreach (var resource in Model.Resources)
            {
                <tr>
                    <td colspan="5">
                        <form method="post" asp-page-handler="Save" class="row g-2 align-items-end">
                            <input type="hidden" name="ResourceID" value="@resource.ResourceID" />
                            <div class="col-md-3"><input class="form-control" name="Title" value="@resource.Title" required /></div>
                            <div class="col-md-2">
                                <select class="form-select" name="SkillID">
                                    @foreach (var skill in Model.Skills)
                                    {
                                        <option value="@skill.SkillID" selected="@(skill.SkillID == resource.SkillID)">@skill.SkillName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <select class="form-select" name="Type">
                                    <option selected="@(resource.Type == "Video")">Video</option>
                                    <option selected="@(resource.Type == "PDF")">PDF</option>
                                    <option selected="@(resource.Type == "Link")">Link</option>
                                </select>
                            </div>
                            <div class="col-md-3"><input class="form-control" name="URL" value="@resource.URL" required /></div>
                            <div class="col-md-2"><button class="btn btn-sm btn-outline-primary" type="submit">Update</button></div>
                            <div class="col-12"><input class="form-control" name="Description" value="@resource.Description" required /></div>
                        </form>
                        <form method="post" asp-page-handler="Delete" class="mt-2">
                            <input type="hidden" name="id" value="@resource.ResourceID" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
