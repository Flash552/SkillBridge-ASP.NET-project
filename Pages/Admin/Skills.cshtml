@page
@model MyWebApp.Pages.Admin.SkillsModel
@{
    ViewData["Title"] = "Manage Skills";
}

<h1>Manage Skills</h1>

<div class="form-panel mb-4">
    <h2 class="h4">Add Skill</h2>
    <form method="post" asp-page-handler="Save">
        <input type="hidden" name="SkillID" value="0" />
        <div class="mb-3">
            <label class="form-label">Skill Name</label>
            <input class="form-control" name="SkillName" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" name="Description" required></textarea>
        </div>
        <button class="btn btn-primary" type="submit">Add Skill</button>
    </form>
</div>

<div class="table-panel">
    <table class="table align-middle mb-0">
        <thead><tr><th>Name</th><th>Description</th><th>Actions</th></tr></thead>
        <tbody>
            @foreach (var skill in Model.Skills)
            {
                <tr>
                    <form method="post" asp-page-handler="Save">
                        <input type="hidden" name="SkillID" value="@skill.SkillID" />
                        <td><input class="form-control" name="SkillName" value="@skill.SkillName" required /></td>
                        <td><input class="form-control" name="Description" value="@skill.Description" required /></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" type="submit">Update</button>
                        </td>
                    </form>
                    <td>
                        <form method="post" asp-page-handler="Delete">
                            <input type="hidden" name="id" value="@skill.SkillID" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
