@page
@model MyWebApp.Pages.Member.QuizCentreModel
@{
    ViewData["Title"] = "Quiz Centre";
}

<h1>Quiz Centre</h1>
<p class="text-muted">Choose a quiz to test your skill knowledge.</p>

<div class="row g-3">
    @foreach (var quiz in Model.Quizzes)
    {
        <div class="col-md-6">
            <div class="section-card p-4 h-100">
                <span class="skill-badge">@quiz.SkillName</span>
                <h2 class="h4 mt-3">@quiz.QuizTitle</h2>
                <p class="text-muted">Total marks: @quiz.TotalMarks</p>
                <a class="btn btn-primary" asp-page="/Member/AttemptQuiz" asp-route-id="@quiz.QuizID">Attempt Quiz</a>
            </div>
        </div>
    }
</div>
