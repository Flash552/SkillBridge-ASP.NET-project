@page
@model MyWebApp.Pages.Member.MyProgressModel
@{
    ViewData["Title"] = "My Progress";
}

<h1>My Progress</h1>
<p class="text-muted">Resources you started or completed.</p>

<div class="table-panel">
    <table class="table table-striped mb-0">
        <thead>
            <tr>
                <th>Resource</th>
                <th>Skill</th>
                <th>Status</th>
                <th>Date Completed</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Progress)
            {
                <tr>
                    <td>@item.ResourceTitle</td>
                    <td>@item.SkillName</td>
                    <td>@item.Status</td>
                    <td>@(item.DateCompleted ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
