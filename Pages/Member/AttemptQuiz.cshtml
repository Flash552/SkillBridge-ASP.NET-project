@page "{id:int}"
@model MyWebApp.Pages.Member.AttemptQuizModel
@{
    ViewData["Title"] = "Attempt Quiz";
}

@if (Model.Quiz is null)
{
    <div class="alert alert-warning">Quiz not found.</div>
}
else
{
    <div class="section-card p-4">
        <span class="skill-badge">@Model.Quiz.SkillName</span>
        <h1 class="mt-3">@Model.Quiz.QuizTitle</h1>

        @if (Model.ScoreMessage is not null)
        {
            <div class="alert alert-success">@Model.ScoreMessage</div>
            <a class="btn btn-primary" asp-page="/Member/QuizCentre">Back to Quiz Centre</a>
        }
        else
        {
            <form method="post">
                <input type="hidden" name="id" value="@Model.Quiz.QuizID" />
                @for (var i = 0; i < Model.Questions.Count; i++)
                {
                    var question = Model.Questions[i];
                    <div class="border-top py-3">
                        <p class="fw-semibold mb-2">@(i + 1). @question.QuestionText</p>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Answers[@question.QuestionID]" value="A" required />
                            <label class="form-check-label">@question.OptionA</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Answers[@question.QuestionID]" value="B" />
                            <label class="form-check-label">@question.OptionB</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Answers[@question.QuestionID]" value="C" />
                            <label class="form-check-label">@question.OptionC</label>
                        </div>
                    </div>
                }
                <button class="btn btn-success mt-3" type="submit">Submit Quiz</button>
            </form>
        }
    </div>
}
