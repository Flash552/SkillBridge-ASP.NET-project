@page "{id:int}"
@model MyWebApp.Pages.Resources.DetailsModel
@{
    ViewData["Title"] = Model.Resource?.Title ?? "Resource";
}

@if (Model.Resource is null)
{
    <div class="alert alert-warning">Resource not found.</div>
}
else
{
    <div class="section-card p-4 p-lg-5">
        <span class="skill-badge">@Model.Resource.SkillName</span>
        <h1 class="mt-3">@Model.Resource.Title</h1>
        <p class="lead text-muted">@Model.Resource.Description</p>

        <div class="mb-4">
            <span class="type-pill type-@Model.Resource.Type.ToLowerInvariant()">@Model.Resource.Type</span>
        </div>

        @if (Model.Resource.Type == "Video")
        {
            <p>This resource uses a video link. Open it in a new tab to watch the lesson.</p>
        }
        else if (Model.Resource.Type == "PDF")
        {
            <p>This resource links to a PDF learning material.</p>
        }
        else
        {
            <p>This resource links to an external learning website.</p>
        }

        <a class="btn btn-primary" href="@Model.Resource.URL" target="_blank" rel="noopener">Open Resource</a>

        @if (Model.IsMemberUser)
        {
            <form method="post" class="d-inline">
                <input type="hidden" name="resourceId" value="@Model.Resource.ResourceID" />
                <button class="btn btn-outline-secondary ms-2" type="submit" name="status" value="In Progress">Mark In Progress</button>
                <button class="btn btn-success ms-2" type="submit" name="status" value="Completed">Mark Completed</button>
            </form>
        }
        else
        {
            <a class="btn btn-outline-primary ms-2" asp-page="/Account/Login">Login to track progress</a>
        }
    </div>
}
