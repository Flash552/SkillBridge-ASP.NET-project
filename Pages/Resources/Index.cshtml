@page
@model MyWebApp.Pages.Resources.IndexModel
@{
    ViewData["Title"] = "Resources";
}

<div class="section-card p-4 p-lg-5 mb-4">
    <span class="eyebrow">Resource Library</span>
    <div class="row align-items-end g-3">
        <div class="col-lg-7">
            <h1 class="mb-2">Learning Resources</h1>
            <p class="text-muted mb-0">Browse curated videos, PDFs, and external links by skill area.</p>
        </div>
        <div class="col-lg-5">
            <form method="get" class="d-flex gap-2">
                <select class="form-select" name="skillId" asp-for="SkillId">
                    <option value="">All skills</option>
                    @foreach (var skill in Model.Skills)
                    {
                        <option value="@skill.SkillID">@skill.SkillName</option>
                    }
                </select>
                <button class="btn btn-outline-primary" type="submit">Filter</button>
            </form>
        </div>
    </div>
</div>

<div class="row g-3">
    @foreach (var resource in Model.Resources)
    {
        var typeClass = resource.Type.ToLowerInvariant() switch
        {
            "video" => "type-video",
            "pdf" => "type-pdf",
            _ => "type-link"
        };

        <div class="col-md-6 col-lg-4">
            <div class="resource-card h-100 p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="skill-badge">@resource.SkillName</span>
                    <span class="type-pill @typeClass">@resource.Type</span>
                </div>
                <h2 class="h5 mt-3">@resource.Title</h2>
                <p class="text-muted">@resource.Description</p>
                <div class="d-flex justify-content-between align-items-center">
                    <a class="btn btn-primary btn-sm" asp-page="/Resources/Details" asp-route-id="@resource.ResourceID">View Details</a>
                    <small class="text-muted">SkillBridge</small>
                </div>
            </div>
        </div>
    }
</div>
