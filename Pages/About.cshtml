@page
@model MyWebApp.Pages.AboutModel
@{
    ViewData["Title"] = "About";
}

<div class="section-card p-4 p-lg-5">
    <h1>About SkillBridge</h1>
    <p class="lead text-muted">
        SkillBridge is an ASP.NET Core learning platform that organises study resources by practical skills instead of course names.
    </p>

    <h2 class="h4 mt-4">Mission Statement</h2>
    <p>To help learners discover focused digital learning resources, practise through quizzes, and track their progress in one simple web application.</p>

    <h2 class="h4 mt-4">Audience</h2>
    <p>SkillBridge is designed for students and self-learners who want to improve skills in Programming, Maths, Design, and Communication.</p>

    <h2 class="h4 mt-4">Project Scope</h2>
    <p class="mb-0">
        Guests can browse public resources. Members can register, log in, attempt quizzes, track progress, and view history. Admins can manage users, skills, resources, quizzes, and questions.
    </p>
</div>
